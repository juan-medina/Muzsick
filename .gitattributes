# ----- Line-ending normalisation ----------------------------------
* text=auto

# C# / .NET sources — always LF in the repo
*.cs    text eol=lf
*.axaml text eol=lf
*.xaml  text eol=lf
*.csproj text eol=lf
*.sln   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.editorconfig text eol=lf

# ----- Binary assets (no diffs, no merges) -----------------------
*.ico   binary
*.svg   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.wav   binary
*.mp3   binary

# ----- Git LFS — large ML model files ----------------------------
# Kokoro-82M ONNX model + vocabulary/token data (~80 MB total)
# Tracked via Git LFS so they live in the repo without inflating
# the regular object store.  Requires `git lfs install` on first clone.
*.onnx filter=lfs diff=lfs merge=lfs -text
*.bin  filter=lfs diff=lfs merge=lfs -text
*.dat  filter=lfs diff=lfs merge=lfs -text
