<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Muzsick.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="540" d:DesignHeight="680"
        x:Class="Muzsick.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/muzsick-logo.ico"
        Title="Muzsick"
        Width="540"
        Height="680"
        CanResize="False">

	<Design.DataContext>
		<vm:MainWindowViewModel />
	</Design.DataContext>

	<DockPanel Background="#2B2B2B" LastChildFill="True">

		<!-- Header with Artist Image -->
		<DockPanel DockPanel.Dock="Top" Height="70" Background="#1E1E1E" Margin="0,0,0,0">
			<!-- Settings button docked to the far right -->
			<Button DockPanel.Dock="Right"
			        Command="{Binding OpenConfigCommand}"
			        Width="36" Height="36"
			        Margin="10,0"
			        Background="Transparent"
			        BorderThickness="0"
			        VerticalAlignment="Center"
			        ToolTip.Tip="Settings"
			        Classes="settingsButton">
				<TextBlock Text="⚙" FontSize="18" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center" />
			</Button>
			<Border Width="60" Height="60" Margin="10" Background="#444444" CornerRadius="30"
			        ClipToBounds="True">
				<Panel>
					<!-- Placeholder: shown when no artist image available -->
					<Canvas Width="60" Height="60"
					        IsVisible="{Binding ArtistImage, Converter={x:Static ObjectConverters.IsNull}}">
						<Ellipse Canvas.Left="0" Canvas.Top="0" Width="60" Height="60" Fill="#2d2d2d" />
						<Ellipse Canvas.Left="21" Canvas.Top="9" Width="18" Height="18" Fill="#999999" />
						<Ellipse Canvas.Left="15" Canvas.Top="30" Width="30" Height="25" Fill="#999999" />
					</Canvas>
					<!-- Real artist image: shown when Bitmap is available -->
					<Image Source="{Binding ArtistImage}"
					       Width="60" Height="60"
					       Stretch="UniformToFill"
					       IsVisible="{Binding ArtistImage, Converter={x:Static ObjectConverters.IsNotNull}}" />
				</Panel>
			</Border>
			<StackPanel VerticalAlignment="Center" Margin="10,0,20,0">
				<TextBlock Text="Now Playing" FontSize="11" Foreground="#888888" />
				<TextBlock Text="{Binding ArtistName}" FontSize="14" Foreground="#FFFFFF" FontWeight="Bold"
				           TextTrimming="CharacterEllipsis" />
				<TextBlock Text="{Binding SongTitle}" FontSize="12" Foreground="#CCCCCC" TextTrimming="CharacterEllipsis" />
			</StackPanel>
		</DockPanel>

		<!-- Main Content Area -->
		<StackPanel DockPanel.Dock="Top" Spacing="16" Margin="20,12,20,20" VerticalAlignment="Top">

			<!-- Album Cover -->
			<Grid HorizontalAlignment="Center" Margin="0,0,0,0">
				<Border Width="300" Height="300" Background="#444444" CornerRadius="12"
				        Effect="drop-shadow(0 4 8 #00000080)" ClipToBounds="True">
					<Panel>
						<!-- Placeholder: shown when no album art available -->
						<Canvas Width="300" Height="300"
						        IsVisible="{Binding AlbumArt, Converter={x:Static ObjectConverters.IsNull}}">
							<Rectangle Canvas.Left="0" Canvas.Top="0" Width="300" Height="300" Fill="#444444" />
							<Ellipse Canvas.Left="10" Canvas.Top="10" Width="280" Height="280" Fill="#1a1a1a" />
							<Ellipse Canvas.Left="20" Canvas.Top="20" Width="260" Height="260" Fill="#2d2d2d" />
							<Ellipse Canvas.Left="30" Canvas.Top="30" Width="240" Height="240" Fill="Transparent" Stroke="#1a1a1a"
							         StrokeThickness="2" Opacity="0.3" />
							<Ellipse Canvas.Left="50" Canvas.Top="50" Width="200" Height="200" Fill="Transparent" Stroke="#1a1a1a"
							         StrokeThickness="2" Opacity="0.3" />
							<Ellipse Canvas.Left="70" Canvas.Top="70" Width="160" Height="160" Fill="Transparent" Stroke="#1a1a1a"
							         StrokeThickness="2" Opacity="0.3" />
							<Ellipse Canvas.Left="90" Canvas.Top="90" Width="120" Height="120" Fill="Transparent" Stroke="#1a1a1a"
							         StrokeThickness="2" Opacity="0.3" />
							<Ellipse Canvas.Left="115" Canvas.Top="115" Width="70" Height="70" Fill="#FF6B35" />
							<Ellipse Canvas.Left="125" Canvas.Top="125" Width="50" Height="50" Fill="#2d2d2d" />
							<Ellipse Canvas.Left="142" Canvas.Top="142" Width="16" Height="16" Fill="#FF6B35" />
							<TextBlock Canvas.Left="130" Canvas.Top="270" Text="No Album Art" FontSize="14" Foreground="#999999" />
						</Canvas>
						<!-- Real album art: shown when Bitmap is available -->
						<Image Source="{Binding AlbumArt}"
						       Width="300" Height="300"
						       Stretch="UniformToFill"
						       IsVisible="{Binding AlbumArt, Converter={x:Static ObjectConverters.IsNotNull}}" />
					</Panel>
				</Border>
			</Grid>

			<!-- Song Information -->
			<StackPanel Spacing="10" HorizontalAlignment="Center" Width="520">
				<TextBlock
					Text="{Binding SongTitle}"
					FontSize="22"
					FontWeight="Bold"
					Foreground="#FFFFFF"
					TextAlignment="Center"
					TextTrimming="CharacterEllipsis"
					LineHeight="26" />
				<TextBlock
					Text="{Binding ArtistName}"
					FontSize="16"
					Foreground="#CCCCCC"
					TextAlignment="Center"
					TextTrimming="CharacterEllipsis" />
				<TextBlock
					Text="{Binding AlbumName}"
					FontSize="14"
					Foreground="#999999"
					TextAlignment="Center"
					TextTrimming="CharacterEllipsis" />
			</StackPanel>

			<!-- Volume Control -->
			<StackPanel HorizontalAlignment="Center" Width="520" Spacing="6">
				<DockPanel>
					<TextBlock DockPanel.Dock="Left" Text="🔈" FontSize="14" Foreground="#888888" VerticalAlignment="Center" />
					<TextBlock DockPanel.Dock="Right" Text="🔊" FontSize="14" Foreground="#888888" VerticalAlignment="Center" />
					<Grid Margin="8,0">
						<Slider
							Minimum="0"
							Maximum="100"
							Value="{Binding Volume}"
							TickFrequency="1"
							IsSnapToTickEnabled="True"
							VerticalAlignment="Center" />
						<!-- Floating volume label — visible briefly when volume changes -->
						<Border
							HorizontalAlignment="Center"
							VerticalAlignment="Top"
							Margin="0,-10,0,0"
							Background="#CC4A1A00"
							CornerRadius="4"
							Padding="6,2"
							IsVisible="{Binding VolumeTooltipVisible}">
							<TextBlock
								Text="{Binding Volume, StringFormat={}{0}%}"
								FontSize="13"
								Foreground="#FF6B35"
								FontWeight="Bold" />
						</Border>
					</Grid>
				</DockPanel>
			</StackPanel>

			<!-- Control Buttons -->
			<StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center" Margin="0,8,0,8">
				<!-- Open Playlist — secondary action, left of play -->
				<Button
					Width="44"
					Height="44"
					CornerRadius="22"
					Command="{Binding BrowsePlaylistCommand}"
					Background="#444444"
					Foreground="#FFFFFF"
					HorizontalAlignment="Center"
					Classes="browseButton">
					<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
						<Canvas Width="16" Height="16">
							<Path Fill="#FFFFFF" Data="M1 3h5l2 2h7a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" />
						</Canvas>
					</StackPanel>
				</Button>

				<!-- Play / Pause — primary action -->
				<Button
					Width="80"
					Height="80"
					CornerRadius="40"
					Command="{Binding PlayPauseCommand}"
					Background="#FF6B35"
					Foreground="#FFFFFF"
					HorizontalAlignment="Center"
					Classes="playButton">
					<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
						<Canvas Width="28" Height="28" IsVisible="{Binding !IsPlaying}">
							<Polygon Points="8,4 8,24 24,14" Fill="#FFFFFF" />
						</Canvas>
						<Canvas Width="28" Height="28" IsVisible="{Binding IsPlaying}">
							<Rectangle Canvas.Left="7" Canvas.Top="5" Width="5" Height="18" Fill="#FFFFFF" />
							<Rectangle Canvas.Left="16" Canvas.Top="5" Width="5" Height="18" Fill="#FFFFFF" />
						</Canvas>
					</StackPanel>
				</Button>

				<!-- Spacer to balance the browse button on the left -->
				<Border Width="44" Height="44" />
			</StackPanel>
		</StackPanel>
	</DockPanel>

	<Window.Styles>
		<Style Selector="Button.playButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#FF8855" />
		</Style>
		<Style Selector="Button.playButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="#DD5520" />
		</Style>

		<Style Selector="Button.settingsButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#333333" />
		</Style>
		<Style Selector="Button.settingsButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="#222222" />
		</Style>
		<Style Selector="Button.browseButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#555555" />
		</Style>
		<Style Selector="Button.browseButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="#333333" />
		</Style>
	</Window.Styles>

</Window>
