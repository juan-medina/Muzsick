<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Muzsick.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="540" d:DesignHeight="638"
        x:Class="Muzsick.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/muzsick-logo.ico"
        Title="Muzsick"
        Width="540"
        Height="638"
        CanResize="False">

	<Design.DataContext>
		<vm:MainWindowViewModel />
	</Design.DataContext>

	<DockPanel Background="#2B2B2B" LastChildFill="True">

		<!-- Header with Artist Image -->
		<DockPanel DockPanel.Dock="Top" Height="70" Background="#1E1E1E" Margin="0,0,0,0">
			<!-- About button — rightmost -->
			<Button DockPanel.Dock="Right"
			        Command="{Binding OpenAboutCommand}"
			        Width="36" Height="36"
			        Margin="10,0"
			        Background="Transparent"
			        BorderThickness="0"
			        VerticalAlignment="Center"
			        ToolTip.Tip="About"
			        Classes="aboutButton">
				<Viewbox Width="20" Height="20">
					<Canvas Width="256" Height="256">
						<Ellipse Canvas.Left="8" Canvas.Top="8" Width="240" Height="240"
						         Fill="#FF6B35" Stroke="#DD5520" StrokeThickness="4" />
						<Rectangle Canvas.Left="120" Canvas.Top="80" Width="16" Height="96"
						           Fill="#FFFFFF" RadiusX="2" RadiusY="2" />
						<Rectangle Canvas.Left="118" Canvas.Top="78" Width="20" Height="8"
						           Fill="#FFFFFF" RadiusX="2" RadiusY="2" />
						<Path Data="M 95 128 Q 128 105 161 128" Stroke="#FFFFFF" StrokeThickness="4" Fill="Transparent" Opacity="0.9" />
						<Path Data="M 95 128 Q 128 151 161 128" Stroke="#FFFFFF" StrokeThickness="4" Fill="Transparent" Opacity="0.9" />
						<Path Data="M 75 128 Q 128 95 181 128" Stroke="#FFFFFF" StrokeThickness="3" Fill="Transparent" Opacity="0.7" />
						<Path Data="M 75 128 Q 128 161 181 128" Stroke="#FFFFFF" StrokeThickness="3" Fill="Transparent" Opacity="0.7" />
						<Path Data="M 55 128 Q 128 85 201 128" Stroke="#FFFFFF" StrokeThickness="2" Fill="Transparent" Opacity="0.5" />
						<Path Data="M 55 128 Q 128 171 201 128" Stroke="#FFFFFF" StrokeThickness="2" Fill="Transparent" Opacity="0.5" />
						<Ellipse Canvas.Left="167" Canvas.Top="105" Width="6" Height="6" Fill="#FFFFFF" Opacity="0.8" />
						<Ellipse Canvas.Left="183" Canvas.Top="116" Width="4" Height="4" Fill="#FFFFFF" Opacity="0.6" />
						<Ellipse Canvas.Left="188" Canvas.Top="136" Width="4" Height="4" Fill="#FFFFFF" Opacity="0.6" />
						<Ellipse Canvas.Left="177" Canvas.Top="145" Width="6" Height="6" Fill="#FFFFFF" Opacity="0.8" />
					</Canvas>
				</Viewbox>
			</Button>
			<!-- Settings button — to the left of About -->
			<Button DockPanel.Dock="Right"
			        Command="{Binding OpenConfigCommand}"
			        Width="36" Height="36"
			        Margin="0,0,0,0"
			        Background="Transparent"
			        BorderThickness="0"
			        VerticalAlignment="Center"
			        ToolTip.Tip="Settings"
			        Classes="settingsButton">
				<Canvas Width="16" Height="16">
					<Path Fill="#888888"
					      Data="F0 M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34z M8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z" />
				</Canvas>
			</Button>
			<!-- Artist image — click to open Last.fm artist page -->
			<Button Command="{Binding OpenLastFmCommand}"
			        CommandParameter="{Binding ArtistLastFmUrl}"
			        IsEnabled="{Binding ArtistLastFmUrl, Converter={x:Static ObjectConverters.IsNotNull}}"
			        Width="60" Height="60" Margin="10"
			        Background="Transparent" BorderThickness="0" Padding="0"
			        VerticalAlignment="Center"
			        Focusable="False"
			        Classes="lastFmLink">
				<Border Width="60" Height="60" Background="#444444" CornerRadius="30"
				        ClipToBounds="True">
					<Panel>
						<!-- Placeholder: shown when no artist image available -->
						<Canvas Width="60" Height="60"
						        IsVisible="{Binding ArtistImage, Converter={x:Static ObjectConverters.IsNull}}">
							<Ellipse Canvas.Left="0" Canvas.Top="0" Width="60" Height="60" Fill="#2d2d2d" />
							<Ellipse Canvas.Left="21" Canvas.Top="9" Width="18" Height="18" Fill="#999999" />
							<Ellipse Canvas.Left="15" Canvas.Top="30" Width="30" Height="25" Fill="#999999" />
						</Canvas>
						<!-- Real artist image: shown when Bitmap is available -->
						<Image Source="{Binding ArtistImage}"
						       Width="60" Height="60"
						       Stretch="UniformToFill"
						       IsVisible="{Binding ArtistImage, Converter={x:Static ObjectConverters.IsNotNull}}" />
					</Panel>
				</Border>
			</Button>
			<StackPanel VerticalAlignment="Center" Margin="10,0,20,0">
				<TextBlock Text="Now Playing" FontSize="11" Foreground="#888888" />
				<TextBlock Text="{Binding ArtistName}" FontSize="14" Foreground="#FFFFFF" FontWeight="Bold"
				           TextTrimming="CharacterEllipsis" />
				<TextBlock Text="{Binding SongTitle}" FontSize="12" Foreground="#CCCCCC" TextTrimming="CharacterEllipsis" />
			</StackPanel>
		</DockPanel>

		<!-- Update available banner — visible only when an update has been staged -->
		<Border DockPanel.Dock="Top"
		        Background="#CC2A1A00"
		        Padding="16,6"
		        IsVisible="{Binding UpdateMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
			<TextBlock Text="{Binding UpdateMessage}"
			           FontSize="13"
			           Foreground="#FF6B35"
			           FontWeight="SemiBold"
			           HorizontalAlignment="Center" />
		</Border>

		<!-- Status bar -->
		<Border DockPanel.Dock="Bottom"
		        Background="#1A1A1A"
		        BorderBrush="#2E2E2E"
		        BorderThickness="0,1,0,0"
		        Height="28">
			<StackPanel Orientation="Horizontal"
			            VerticalAlignment="Center"
			            Margin="14,0">
				<Ellipse Width="6" Height="6"
				         VerticalAlignment="Center"
				         Margin="0,0,7,0"
				         Fill="{Binding StatusDotColor}"
				         Opacity="{Binding StatusDotOpacity}" />
				<TextBlock Text="{Binding StatusMessage}"
				           FontSize="11"
				           Foreground="{Binding StatusTextColor}"
				           VerticalAlignment="Center" />
			</StackPanel>
		</Border>

		<!-- Main Content Area -->
		<StackPanel DockPanel.Dock="Top" Spacing="16" Margin="20,12,20,20" VerticalAlignment="Top">

			<!-- Album Cover — click to open Last.fm album page -->
			<Grid HorizontalAlignment="Center" Margin="0,0,0,0">
				<Button Command="{Binding OpenLastFmCommand}"
				        CommandParameter="{Binding AlbumLastFmUrl}"
				        IsEnabled="{Binding AlbumLastFmUrl, Converter={x:Static ObjectConverters.IsNotNull}}"
				        Background="Transparent" BorderThickness="0" Padding="0"
				        Focusable="False"
				        Classes="lastFmLink">
					<Border Width="300" Height="300" Background="#444444" CornerRadius="12"
					        Effect="drop-shadow(0 4 8 #00000080)" ClipToBounds="True">
						<Panel>
							<!-- Placeholder: shown when no album art available -->
							<Canvas Width="300" Height="300"
							        IsVisible="{Binding AlbumArt, Converter={x:Static ObjectConverters.IsNull}}">
								<Rectangle Canvas.Left="0" Canvas.Top="0" Width="300" Height="300" Fill="#444444" />
								<Ellipse Canvas.Left="10" Canvas.Top="10" Width="280" Height="280" Fill="#1a1a1a" />
								<Ellipse Canvas.Left="20" Canvas.Top="20" Width="260" Height="260" Fill="#2d2d2d" />
								<Ellipse Canvas.Left="30" Canvas.Top="30" Width="240" Height="240" Fill="Transparent" Stroke="#1a1a1a"
								         StrokeThickness="2" Opacity="0.3" />
								<Ellipse Canvas.Left="50" Canvas.Top="50" Width="200" Height="200" Fill="Transparent" Stroke="#1a1a1a"
								         StrokeThickness="2" Opacity="0.3" />
								<Ellipse Canvas.Left="70" Canvas.Top="70" Width="160" Height="160" Fill="Transparent" Stroke="#1a1a1a"
								         StrokeThickness="2" Opacity="0.3" />
								<Ellipse Canvas.Left="90" Canvas.Top="90" Width="120" Height="120" Fill="Transparent" Stroke="#1a1a1a"
								         StrokeThickness="2" Opacity="0.3" />
								<Ellipse Canvas.Left="115" Canvas.Top="115" Width="70" Height="70" Fill="#FF6B35" />
								<Ellipse Canvas.Left="125" Canvas.Top="125" Width="50" Height="50" Fill="#2d2d2d" />
								<Ellipse Canvas.Left="142" Canvas.Top="142" Width="16" Height="16" Fill="#FF6B35" />
								<TextBlock Canvas.Left="130" Canvas.Top="270" Text="No Album Art" FontSize="14" Foreground="#999999" />
							</Canvas>
							<!-- Real album art: shown when Bitmap is available -->
							<Image Source="{Binding AlbumArt}"
							       Width="300" Height="300"
							       Stretch="UniformToFill"
							       IsVisible="{Binding AlbumArt, Converter={x:Static ObjectConverters.IsNotNull}}" />
						</Panel>
					</Border>
				</Button>
			</Grid>

			<!-- Song Information -->
			<StackPanel Spacing="4" HorizontalAlignment="Center" Width="520">
				<Button Command="{Binding OpenLastFmCommand}"
				        CommandParameter="{Binding TrackLastFmUrl}"
				        IsEnabled="{Binding TrackLastFmUrl, Converter={x:Static ObjectConverters.IsNotNull}}"
				        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
				        Background="Transparent" BorderThickness="0" Padding="2,0"
				        Focusable="False"
				        Classes="lastFmLink">
					<TextBlock
						Text="{Binding SongTitle}"
						FontSize="22"
						FontWeight="Bold"
						Foreground="#FFFFFF"
						TextAlignment="Center"
						TextTrimming="CharacterEllipsis"
						LineHeight="26" />
				</Button>
				<Button Command="{Binding OpenLastFmCommand}"
				        CommandParameter="{Binding ArtistLastFmUrl}"
				        IsEnabled="{Binding ArtistLastFmUrl, Converter={x:Static ObjectConverters.IsNotNull}}"
				        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
				        Background="Transparent" BorderThickness="0" Padding="2,0"
				        Focusable="False"
				        Classes="lastFmLink">
					<TextBlock
						Text="{Binding ArtistName}"
						FontSize="16"
						Foreground="#CCCCCC"
						TextAlignment="Center"
						TextTrimming="CharacterEllipsis" />
				</Button>
				<Button Command="{Binding OpenLastFmCommand}"
				        CommandParameter="{Binding AlbumLastFmUrl}"
				        IsEnabled="{Binding AlbumLastFmUrl, Converter={x:Static ObjectConverters.IsNotNull}}"
				        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
				        Background="Transparent" BorderThickness="0" Padding="2,0"
				        Focusable="False"
				        Classes="lastFmLink">
					<TextBlock
						Text="{Binding AlbumName}"
						FontSize="14"
						Foreground="#999999"
						TextAlignment="Center"
						TextTrimming="CharacterEllipsis" />
				</Button>
			</StackPanel>

			<!-- Volume Control -->
			<StackPanel HorizontalAlignment="Center" Width="520" Spacing="6">
				<DockPanel>
					<Canvas DockPanel.Dock="Left" Width="16" Height="16" VerticalAlignment="Center">
						<Path Fill="#888888" Data="M2,6 L2,10 L5,10 L9,13 L9,3 L5,6 Z" />
						<Path Fill="Transparent" Stroke="#888888" StrokeThickness="1.5" Data="M11,6 Q13.5,8 11,10" />
					</Canvas>
					<Canvas DockPanel.Dock="Right" Width="16" Height="16" VerticalAlignment="Center">
						<Path Fill="#888888" Data="M2,6 L2,10 L5,10 L9,13 L9,3 L5,6 Z" />
						<Path Fill="Transparent" Stroke="#888888" StrokeThickness="1.5" Data="M11,6 Q13.5,8 11,10" />
						<Path Fill="Transparent" Stroke="#888888" StrokeThickness="1.5" Data="M12.5,4.5 Q15.5,8 12.5,11.5" />
						<Path Fill="Transparent" Stroke="#888888" StrokeThickness="1.5" Data="M14,3.5 Q17,8 14,12.5" />
					</Canvas>
					<Grid Margin="8,0">
						<Slider
							Minimum="0"
							Maximum="100"
							Value="{Binding Volume}"
							TickFrequency="1"
							IsSnapToTickEnabled="True"
							VerticalAlignment="Center" />
						<!-- Floating volume label — visible briefly when volume changes -->
						<Border
							HorizontalAlignment="Center"
							VerticalAlignment="Top"
							Margin="0,-10,0,0"
							Background="#CC4A1A00"
							CornerRadius="4"
							Padding="6,2"
							IsVisible="{Binding VolumeTooltipVisible}">
							<TextBlock
								Text="{Binding Volume, StringFormat={}{0}%}"
								FontSize="13"
								Foreground="#FF6B35"
								FontWeight="Bold" />
						</Border>
					</Grid>
				</DockPanel>
			</StackPanel>

			<!-- Control Buttons -->
			<StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center" Margin="0,8,0,8">

				<!-- History — opens session history window -->
				<Button
					Width="44"
					Height="44"
					CornerRadius="22"
					Command="{Binding OpenHistoryCommand}"
					Background="#444444"
					Foreground="#FFFFFF"
					HorizontalAlignment="Center"
					ToolTip.Tip="Played this session"
					Classes="historyButton">
					<Canvas Width="16" Height="16">
						<Rectangle Canvas.Left="2" Canvas.Top="2.5" Width="12" Height="2" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
						<Rectangle Canvas.Left="2" Canvas.Top="7" Width="12" Height="2" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
						<Rectangle Canvas.Left="2" Canvas.Top="11.5" Width="12" Height="2" Fill="#FFFFFF" RadiusX="1" RadiusY="1" />
					</Canvas>
				</Button>

			</StackPanel>

		</StackPanel>
	</DockPanel>

	<Window.Styles>
		<Style Selector="Button.lastFmLink">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="Cursor" Value="Hand" />
		</Style>
		<Style Selector="Button.lastFmLink /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="Button.lastFmLink:pointerover">
			<Setter Property="Opacity" Value="0.72" />
		</Style>
		<Style Selector="Button.lastFmLink:pressed">
			<Setter Property="Opacity" Value="0.50" />
		</Style>
		<!-- Disabled: no cursor change is handled by Avalonia automatically,
		     but we must prevent the default opacity dimming so it looks like plain text/image. -->
		<Style Selector="Button.lastFmLink:disabled">
			<Setter Property="Opacity" Value="1" />
		</Style>
		<Style Selector="Button.lastFmLink:disabled /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Opacity" Value="1" />
		</Style>

		<Style Selector="Button.playButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#FF8855" />
		</Style>
		<Style Selector="Button.playButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="#DD5520" />
		</Style>

		<Style Selector="Button.settingsButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#333333" />
		</Style>
		<Style Selector="Button.settingsButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="#222222" />
		</Style>
		<Style Selector="Button.browseButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#555555" />
		</Style>
		<Style Selector="Button.browseButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="#333333" />
		</Style>
		<Style Selector="Button.historyButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#555555" />
		</Style>
		<Style Selector="Button.historyButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="#333333" />
		</Style>
		<Style Selector="Button.aboutButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#333333" />
		</Style>
		<Style Selector="Button.aboutButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="#222222" />
		</Style>
	</Window.Styles>
</Window>
