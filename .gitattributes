# ----- Line-ending normalisation ----------------------------------
* text=auto

# C# / .NET sources — always LF in the repo
*.cs    text eol=lf
*.axaml text eol=lf
*.xaml  text eol=lf
*.csproj text eol=lf
*.sln   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.editorconfig text eol=lf

# ----- Binary assets (no diffs, no merges) -----------------------
*.ico   binary
*.svg   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.wav   binary
*.mp3   binary

# ----- Binary assets (ML models) — not tracked, downloaded at build time -----
# The Kokoro TTS model lives in models/ which is gitignored.
# MSBuild downloads it automatically on first build via dotnet build.
*.onnx -text
*.bin  -text
*.dat  -text
