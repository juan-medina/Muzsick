# ============================================================
#  Muzsick — .gitignore
# ============================================================

# ----- Build output ----------------------------------------
bin/
obj/
out/
publish/

# ----- .NET / NuGet ----------------------------------------
*.user
*.suo
*.userprefs
*.userosscache
*.sln.docstates
project.lock.json
project.fragment.lock.json
artifacts/
packages/
*.nupkg
*.snupkg

# ----- Rider -----------------------------------------------
.idea/
*.sln.iml

# ----- Visual Studio (in case anyone opens it) -------------
.vs/
*.rsuser
*.VC.db
*.VC.VC.opendb

# ----- OS --------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----- Logs & temp -----------------------------------------
*.log
*.tmp
*.temp
crash-*.txt

# ----- Secrets & config overrides --------------------------
# Keep settings.json.example in source, ignore real one if it has keys
secrets.json
local.settings.json

# ----- Application credentials — never committed ----------
src/Muzsick/ApiKeys.json

# ----- ML models — downloaded at build time, never committed ----------
# The Kokoro TTS model is fetched automatically by MSBuild on first build.
models/
